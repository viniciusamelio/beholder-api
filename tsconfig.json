{
  "compilerOptions": {
    "lib": [
      "ESNext"
    ],
    "paths": {
      "@/*" : ["./src/*"]
    },
    "module": "ESNext",
    "target": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "rootDir": "./src",
    "noEmit": true
  },
  "include": [
    "src"
  ]
}